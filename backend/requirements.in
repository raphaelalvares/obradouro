# Runtime do backend CRIA — FONTE das deps (ranges + comentários, editável à mão).
#
# requirements.txt é GERADO a partir deste arquivo (pinado + hashes) — não editar à mão.
# Recompilar (na RAIZ do repo, com Docker, p/ resolver igual à imagem de prod):
#   docker run --rm -v "${PWD}/backend:/w" -w /w python:3.12-slim sh -c \
#     "pip install -q pip-tools && \
#      pip-compile -q --generate-hashes --strip-extras -o requirements.txt requirements.in && \
#      pip-compile -q --generate-hashes --strip-extras -o requirements-dev.txt requirements-dev.in"
