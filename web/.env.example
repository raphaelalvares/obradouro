# Painel web CRIA — variáveis de ambiente (Vite expõe só as prefixadas com VITE_).
# Copie para .env.local e preencha. NUNCA versionar segredos reais.

# API Python (backend FastAPI)
VITE_API_BASE_URL=http://localhost:8000

# Supabase Auth (browser usa SÓ para login/sessão; o resto é via a API acima).
# A anon key é pública por design (protegida por RLS); mesmo assim, não versionar a real.
VITE_SUPABASE_URL=https://<seu-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<sua-anon-key>
