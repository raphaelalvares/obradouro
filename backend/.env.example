# Copie para .env e preencha. NUNCA commite o .env (já está no .gitignore).
# Em produção, defina estes valores nas Environment Variables do EasyPanel.

# Ambiente: development | production
ENVIRONMENT=development

# ---- Supabase (Project Settings > API) ----
SUPABASE_URL=https://SEU_REF.supabase.co
# Service/secret key: ADMIN. Cria usuários e ignora RLS. SÓ no backend, NUNCA nos apps.
# Prefira a nova chave sb_secret_... (substitui a service_role JWT legada eyJ...).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_defina_no_easypanel
# Chave pública (sb_publishable_... ou anon): Settings > API > Project API keys (anon/public).
# OBRIGATÓRIA p/ o login do BFF (B6) — o backend a usa como `apikey` ao chamar o GoTrue
# (/auth/login, /refresh, /logout). É a chave PÚBLICA (a mesma do front), não a service_role.
SUPABASE_ANON_KEY=

# ---- Postgres (Dashboard > Connect > Session pooler) ----
# Driver asyncpg (sufixo +asyncpg obrigatório). Modo recomendado: Supavisor Session Pooler
# (IPv4, porta 5432) — ver docs/infra-notes.md. Faça URL-encode da senha se tiver @ : / espaço.
# IMPORTANTE: conectar como a role DEDICADA cria_app (NÃO postgres) — assim a RLS (2ª camada)
# vale no caminho da API. Usuário do pooler = cria_app.<project-ref>.
# Defina a senha uma vez no Supabase:  alter role cria_app password '<SENHA_FORTE>';
DATABASE_URL=postgresql+asyncpg://cria_app.SEU_REF:SENHA_URLENCODED@aws-REGIAO.pooler.supabase.com:5432/postgres
# SSL do DB. DEV no Windows: DB_SSL_INSECURE=true (TLS sem verificar a cadeia; o pooler usa CA
# própria). PROD: deixe DB_SSL_INSECURE de fora e use DB_SSL_ROOT_CERT apontando p/ a CA do
# Supabase (baixe em Settings > Database > SSL Configuration -> backend/certs/supabase-ca.crt).
# DB_SSL_INSECURE=true
# DB_SSL_ROOT_CERT=/app/certs/supabase-ca.crt

# ---- CORS (origens do painel web, separadas por vírgula) ----
# DEV (local):
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# PROD (EasyPanel) — usar o domínio do front:
#   CORS_ORIGINS=https://obradouro.com.br,https://www.obradouro.com.br
# Opcional: liberar previews da Vercel via regex (ramos/PRs com URL dinâmica):
#   CORS_ORIGIN_REGEX=^https://obradouro-[a-z0-9-]+\.vercel\.app$
# (Atenção: CORS é a origem da PÁGINA no browser = o front. NÃO é api.obradouro.com.br.)

# ---- Storage de anexos (Fase 4) ----
# Backend de BYTES atrás do módulo app.services.storage (interface trocável).
# 'local' = disco (dev, sem credencial). Em prod, implementar Drive/S3 e trocar aqui.
STORAGE_BACKEND=local
# Raiz do adapter 'local' (fora do git). Em prod com volume persistente, aponte p/ o volume.
STORAGE_DIR=.storage
# Limites de upload/processamento de imagem:
MAX_UPLOAD_MB=25
THUMB_MAX_PX=512
FULL_MAX_PX=2560

# ---- Auth BFF / cookies de sessão (B6) ----
# Atributos dos cookies httpOnly (cria_access/refresh/csrf) que o backend grava no login.
# PROD: front (Vercel) e API (api.obradouro.com.br) são cross-site → use os DEFAULTS abaixo
#   (SECURE=true, SAMESITE=none). Basta a API estar em HTTPS (Traefik). Nada a setar.
# DEV local (http): o browser REJEITA SameSite=None sem HTTPS → descomente as 2 linhas:
#   AUTH_COOKIE_SECURE=false
#   AUTH_COOKIE_SAMESITE=lax
# AUTH_COOKIE_DOMAIN: deixe vazio (cookie host-only no domínio da API). Só preencha se um dia
#   front e API ficarem no MESMO domínio-raiz e você quiser compartilhar (ex.: .obradouro.com.br).
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=none
# AUTH_COOKIE_DOMAIN=
